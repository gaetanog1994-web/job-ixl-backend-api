# Backend API (Node/Express)
# Required runtime variables
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/postgres?sslmode=require
GRAPH_SERVICE_URL=http://localhost:8787
GRAPH_SERVICE_TOKEN=CHANGE_ME_GRAPH_SHARED_TOKEN

# Non-secret runtime config
# Environment model
# APP_ENV: development | staging | production
APP_ENV=development
NODE_ENV=development
PORT=3000
CORS_ALLOWLIST=http://localhost:5173,http://127.0.0.1:5173
MAP_CACHE_TTL_MS=15000

# Optional safety gates (recommended for staging/prod)
# ENABLE_DEBUG_ENDPOINTS=false
# ENABLE_HARNESS_ENDPOINTS=false

# Optional (production TLS CA path for DB)
# SUPABASE_DB_CA_PATH=/absolute/path/to/prod-ca-2021.crt

# Optional lightweight error tracking sink (webhook-compatible provider)
# ERROR_TRACKING_WEBHOOK_URL=https://your-ingest-endpoint.example.com/events
# ERROR_TRACKING_TIMEOUT_MS=2000

# Test-only (backend-api/tests)
BASE_URL=http://localhost:3000
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
